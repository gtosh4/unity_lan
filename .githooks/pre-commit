#!/usr/bin/env bash
# Pre-commit: the same gates CI enforces (fmt + clippy + test), run locally so drift
# never reaches a push. Enable once per clone:  git config core.hooksPath .githooks
# Bypass a single commit with:  git commit --no-verify
set -euo pipefail

# Skip the cargo gates when the commit touches no Rust build inputs (docs, scripts,
# assets, etc.). Anything under a source tree or that changes the build is in scope.
if ! git diff --cached --name-only --diff-filter=ACMR \
    | grep -Eq '\.rs$|(^|/)Cargo\.(toml|lock)$|(^|/)rust-toolchain'; then
  echo "pre-commit: no Rust changes staged, skipping cargo gates"
  exit 0
fi

echo "pre-commit: cargo fmt --all --check"
cargo fmt --all --check

echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "pre-commit: cargo test --workspace"
cargo test --workspace

# Dependency-vuln audit — only when this commit touches Cargo.lock (deps are all it checks), so it
# stays off the hot path of everyday commits. Skipped if cargo-audit isn't installed.
if git diff --cached --name-only | grep -qx 'Cargo.lock'; then
    if command -v cargo-audit >/dev/null 2>&1; then
        echo "pre-commit: cargo audit (Cargo.lock changed)"
        cargo audit
    else
        echo "pre-commit: Cargo.lock changed but cargo-audit not installed — skipping (cargo install cargo-audit)"
    fi
fi

echo "pre-commit: OK"
