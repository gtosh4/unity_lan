<?xml version="1.0" encoding="utf-8"?>
<!--
  UnityLAN Windows installer (WiX v4/v5). Builds an .msi that:
    - installs unitylan-engine.exe + unitylan-gui.exe under Program Files\UnityLAN,
    - stages the wireguard-nt DLL where defguard loads it (resources-windows\binaries\, relative to
      the engine exe — the service pins its CWD there so the relative load resolves),
    - drops a Start-menu shortcut to the GUI,
    - registers + removes the LocalSystem service by calling the engine's own `service install`/
      `service uninstall`.

  It does NOT install engine.toml — the engine owns its config at %ProgramData%\UnityLAN\engine.toml
  (created/migrated by `service install`), so upgrades and uninstalls never touch it.

  Build (see build.ps1) supplies these preprocessor vars via `wix build -d`:
    Version, EngineExe, GuiExe, WgDll
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="UnityLAN"
           Manufacturer="gtosh4"
           Version="$(Version)"
           UpgradeCode="7E6B2C1A-9F84-4D3B-B2A7-1C5E8A0F4D22"
           Scope="perMachine">

    <!-- Remove the old version wholesale before laying down the new one, so the service is torn
         down and re-registered cleanly rather than double-installed. -->
    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of UnityLAN is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Add/Remove Programs metadata. -->
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/gtosh4/unity_lan" />

    <!-- Directory tree: Program Files\UnityLAN\resources-windows\binaries\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="UnityLAN">
        <Directory Id="ResourcesWindowsDir" Name="resources-windows">
          <Directory Id="BinariesDir" Name="binaries" />
        </Directory>
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <ComponentGroup Id="EngineFiles" Directory="INSTALLFOLDER">
      <Component>
        <File Id="EngineExe" Name="unitylan-engine.exe" Source="$(EngineExe)" KeyPath="yes" />
      </Component>
      <Component>
        <File Id="GuiExe" Name="unitylan-gui.exe" Source="$(GuiExe)" KeyPath="yes">
          <!-- Non-advertised shortcut targeting the installed GUI exe. Bare launch => the GUI
               connects to \\.\pipe\unitylan-control, the same pipe the engine serves by default. -->
          <Shortcut Id="GuiShortcut" Directory="ProgramMenuFolder" Name="UnityLAN"
                    Description="Mesh status and device management" Advertise="no" />
        </File>
      </Component>
      <!-- A second, identical copy of the GUI under a name that is never in use. On a /quiet
           MajorUpgrade the real unitylan-gui.exe is locked whenever the GUI is open, so the installer
           reboot-defers it; this copy replaces cleanly (no lock), giving the running GUI the new bytes
           it renames into place to finish the update in-session without a reboot (App::relaunch ->
           swap_in_staged_gui). It's consumed (renamed) by that swap and re-laid by the next install. -->
      <Component>
        <File Id="GuiExeStaged" Name="unitylan-gui.new.exe" Source="$(GuiExe)" KeyPath="yes" />
      </Component>
      <!-- No engine.toml here on purpose. Config lives at %ProgramData%\UnityLAN\engine.toml, written
           and owned by the engine (`service install` / the service's own startup — see
           `service::ensure_config`), not the installer. Keeping it out of the MSI's file list means an
           upgrade or uninstall never touches it, which is what finally retires the bug where
           RemoveExistingProducts deleted the config out from under `service install`. A legacy config
           beside the exe (from installs before this move) is migrated to ProgramData on first run. -->
    </ComponentGroup>

    <Component Id="WgDllComponent" Directory="BinariesDir">
      <File Id="WgDll" Name="wireguard-amd64.dll" Source="$(WgDll)" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="UnityLAN" Level="1">
      <ComponentGroupRef Id="EngineFiles" />
      <ComponentRef Id="WgDllComponent" />
    </Feature>

    <!-- Register/adopt/remove the service via the engine's own installer path. Deferred + no
         impersonation => runs as LocalSystem, which the service create needs. `service install`
         with no config arg bootstraps %ProgramData%\UnityLAN\engine.toml (migrating a legacy
         beside-exe config, else writing the shipped default — see `service::ensure_config`) and bakes
         that absolute path into the service command line, so CWD does not matter.

         On a major upgrade we deliberately do NOT delete the outgoing service — StopService only
         *stops* it (freeing the exe for RemoveFiles) and leaves the registration in place, so the
         incoming build's `service install` adopts and repoints it (create_or_adopt's
         ERROR_SERVICE_EXISTS path) rather than creating a fresh one. Deleting-then-recreating (the
         old design) risked a marked-for-delete husk that wedged the reinstall, and a failed upgrade
         left the machine with no service at all. A genuine uninstall still removes it outright. -->
    <CustomAction Id="InstallService" FileRef="EngineExe" ExeCommand="service install"
                  Execute="deferred" Impersonate="no" Return="check" />
    <CustomAction Id="StopService" FileRef="EngineExe" ExeCommand="service stop"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="UninstallService" FileRef="EngineExe" ExeCommand="service uninstall"
                  Execute="deferred" Impersonate="no" Return="ignore" />
    <!-- Start the freshly-installed service on any install that lays it down — both a first-time
         install and a major upgrade (see the NOT Installed condition below; `Installed` is false for
         the new product in both cases). The upgrade case is the auto-update path: the running engine
         launched msiexec and exited, so without this the new service stays stopped until reboot,
         leaving the mesh down. The first-install case shipped engine.toml already points at a real
         coordinator (packaging\windows\engine.toml), and enrollment is interactive via the GUI, so
         the daemon comes up "not enrolled" and the just-launched GUI prompts login — no reboot, no
         manual `sc.exe start`. Return=ignore so a start hiccup (e.g. a self-hoster who hasn't yet
         repointed `coordinator`) never fails/rolls back the install; they edit config and restart. -->
    <CustomAction Id="StartService" FileRef="EngineExe" ExeCommand="service start"
                  Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Launch the GUI when the user finishes an INTERACTIVE install, via the ExitDialog's
         "Launch UnityLAN now" checkbox (wired up in the UI block below). Immediate + impersonated =>
         runs in the installing user's desktop session, not the LocalSystem/session-0 context the
         service CAs use, so the window actually appears. asyncNoWait: fire and forget, don't block
         Finish. A silent install (/quiet — the auto-update path) shows no ExitDialog, so this never
         fires there; the upgrade just swaps files and restarts the service. -->
    <CustomAction Id="LaunchGui" FileRef="GuiExe" ExeCommand="" Execute="immediate"
                  Impersonate="yes" Return="asyncNoWait" />

    <InstallExecuteSequence>
      <!-- While removing this product's files (both before the exe is deleted): an *upgrade* teardown
           only STOPS the service, leaving it registered for the incoming build to adopt; a genuine
           uninstall removes it. UPGRADINGPRODUCTCODE is set only while RemoveExistingProducts tears
           this product down for a newer build, so the two conditions are mutually exclusive and
           exactly one runs. -->
      <Custom Action="StopService" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot; AND UPGRADINGPRODUCTCODE" />
      <Custom Action="UninstallService" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <!-- Create it (fresh install) or adopt + repoint it at the new exe (upgrade), once files land. -->
      <Custom Action="InstallService" After="InstallFiles" Condition="NOT Installed" />
      <!-- Start it on install and on upgrade (NOT Installed covers both), but not on repair/remove. -->
      <Custom Action="StartService" After="InstallService" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <!-- Custom minimal wizard: WelcomeDlg (a plain welcome — NO license/EULA page) -> progress ->
         ExitDialog. Adapted from the stock WixUI_Minimal
         (github.com/wixtoolset/wix, src/ext/UI/wixlib/WixUI_Minimal.wxs) by dropping its license
         welcome (WelcomeEulaDlg): AGPL-3.0 is a permission grant, not a EULA — GPLv3 §9 ("Acceptance
         Not Required for Having Copies") means running the program requires no acceptance — so the
         install must not gate on "I accept". WelcomeDlg's Next begins the install directly. Every
         other publish is copied verbatim from upstream (maintenance + patch flows). The stock
         dialogs come from the UI extension via WixUI_Common. The only reason a UI exists at all is
         the ExitDialog's "Launch UnityLAN now" checkbox (checked by default), which fires LaunchGui
         on Finish so a first-time user lands straight in the app. The /quiet auto-update path shows
         none of this. -->
    <UI Id="UnityLanUI">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />

      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />
      <DialogRef Id="WelcomeDlg" />

      <!-- Finish button: launch the GUI (async, fire-and-forget) if the box is ticked, then close.
           Order matters — the DoAction must run before the EndDialog that dismisses the wizard. -->
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchGui"
               Order="1" Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999" />

      <!-- First-time install: Next begins the install straight away (this is what WelcomeEulaDlg's
           Install button did upstream, minus the license). -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="EndDialog" Value="Return"
               Condition="NOT Installed" />

      <!-- Maintenance (repair/remove) flow — verbatim from WixUI_Minimal. -->
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg" />
      <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" />

      <!-- Patch flow (Installed AND PATCH) — verbatim from WixUI_Minimal. -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg"
               Condition="Installed AND PATCH" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg"
               Order="2" Condition="Installed AND PATCH" />

      <Property Id="ARPNOMODIFY" Value="1" />
    </UI>
    <UIRef Id="WixUI_Common" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch UnityLAN now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
  </Package>
</Wix>
